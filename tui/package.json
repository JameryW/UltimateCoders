{
  "name": "ultimate-coders-tui",
  "version": "0.1.0",
  "description": "Ink/React terminal UI for UltimateCoders - with CJK/IME support",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx watch src/index.tsx",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "chalk": "^5.3.0",
    "grapheme-splitter": "^1.0.4",
    "ink": "^5.2.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^18.3.1",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
