# UltimateCoders docker runtime config (copy to docker/.env, git-ignored).
#
# docker compose loads .env from the project directory = the parent of the
# first -f compose file. run-gateway.sh / run-cluster.sh use
# -f docker/docker-compose.yml, so the project dir is docker/ — put this
# at docker/.env. (A repo-root .env is NOT loaded.)

# Host workspace path the gateway indexes (uc.repos.yaml scan_dirs).
# Same path in/out of the container — no remapping.
#   Mac:     /Users/<you>/aiworks
#   Linux:   /home/<you>/aiworks
#   Windows: WSL2 path (e.g. /home/<you>/aiworks), not a C:\ path
#
# Required if docker-compose.override.yml exists (it uses :? and errors on
# empty). To run WITHOUT local indexing, delete the override file and leave
# this unset — the gateway then serves external-git repos only.
UC_WORKSPACE_HOST=

# Override the uc.repos.yaml location only if your config lives inside the
# mounted workspace (otherwise the compose-root copy is used).
# UC_REPOS_CONFIG=

# ── External git sync (worker) ──────────────────────────────────────
# Empty UC_REPO_URL = local-only workspace (legacy mode).
# UC_REPO_URL=
# UC_REPO_BASE_BRANCH=main
# UC_GIT_FETCH_ON_ACQUIRE=true
# UC_GIT_PUSH_ON_RELEASE=false
# UC_GIT_TOKEN=
# GIT_USERNAME=x-access-token

