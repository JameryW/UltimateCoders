{
	"type": "module",
	"name": "@ultimate-coders/uc-orchestrator",
	"version": "0.2.0",
	"description": "UltimateCoders Orchestrator extension for oh-my-pi",
	"license": "MIT",
	"scripts": {
		"check": "tsc --noEmit",
		"dev": "cd ../../vendor/oh-my-pi && omp --extension ../../packages/uc-orchestrator",
		"rpc": "bun run src/uc-rpc-server.ts"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.1",
		"@connectrpc/connect": "^2.1.2",
		"@connectrpc/connect-web": "^2.1.2",
		"nats": "^2.29.3"
	},
	"devDependencies": {
		"@bufbuild/protoc-gen-es": "^2.12.1",
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "^13",
		"@oh-my-pi/pi-utils": "^16"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"omp": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	]
}
